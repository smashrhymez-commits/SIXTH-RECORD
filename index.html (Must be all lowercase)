<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>S.R | Sixth Record HQ</title>
    <style>
        body { background-color: #0a0a0a; color: #fff; font-family: 'Helvetica', sans-serif; margin: 0; overflow-x: hidden; }
        .container { padding: 40px; max-width: 1000px; margin: auto; }
        header { border-bottom: 2px solid #333; padding-bottom: 20px; display: flex; justify-content: space-between; align-items: center; text-transform: uppercase; }
        .logo { font-size: 2.5rem; font-weight: bold; letter-spacing: 5px; color: #ff3e3e; }
        .budget-card { background: linear-gradient(145deg, #1a1a1a, #0d0d0d); padding: 30px; border-radius: 2px; margin: 30px 0; border-left: 5px solid #ff3e3e; box-shadow: 0 10px 30px rgba(255, 62, 62, 0.1); }
        .stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; text-align: center; }
        .stat-label { font-size: 0.8rem; color: #888; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 10px; }
        .stat-value { font-size: 2rem; font-weight: bold; font-family: 'Courier New', monospace; }
        .pulse { color: #ff3e3e; animation: blink 1.5s infinite; }
        @keyframes blink { 0% { opacity: 1; } 50% { opacity: 0.3; } 100% { opacity: 1; } }
        .release-section { margin-top: 60px; text-align: center; }
        .artwork-container { width: 320px; height: 320px; margin: 20px auto; border: 1px solid #333; background: #111; overflow: hidden; }
        .artwork-container img { width: 100%; height: 100%; object-fit: cover; }
        .tracklist { max-width: 400px; margin: 20px auto; text-align: left; background: #111; padding: 20px; border: 1px solid #222; }
        .track-row { display: flex; justify-content: space-between; border-bottom: 1px solid #333; padding: 8px 0; font-size: 0.9rem; }
        .btn { background: #ff3e3e; color: white; padding: 18px 40px; text-decoration: none; font-weight: bold; display: inline-block; transition: 0.3s; letter-spacing: 2px; margin-top: 20px; }
        .btn:hover { background: white; color: black; }
    </style>
</head>
<body>

<div class="container">
    <header>
        <div class="logo">S.R</div>
        <nav style="font-size: 0.7rem; letter-spacing: 1px;">DASHBOARD // RELEASES</nav>
    </header>

    <div class="budget-card">
        <h3 style="margin-top:0; letter-spacing: 3px; font-size: 0.9rem;">OPERATIONAL RISK ENGINE v1.0</h3>
        <div class="stat-grid">
            <div><div class="stat-label">Burn</div><div class="stat-value">$2.00<span style="font-size: 0.8rem;">/HR</span></div></div>
            <div><div class="stat-label">Reach</div><div class="stat-value pulse" id="reach">1,200</div></div>
            <div><div class="stat-label">Ceiling</div><div class="stat-value" style="color: #444;">$48.00</div></div>
        </div>
    </div>

    <div class="release-section">
        <div class="stat-label">Latest Drop</div>
        <h2 style="font-size: 3rem; margin: 10px 0;">DECLINE</h2>
        <div class="artwork-container">
            <img src="artwork.jpg" alt="[ S.R ASSET: DECLINE_EP ]">
        </div>
        
        <div class="tracklist">
            <div class="track-row"><span>1. Intro (The Descent)</span><span>02:45</span></div>
            <div class="track-row"><span>2. Real Life Struggles</span><span>03:12</span></div>
            <div class="track-row"><span>3. Silent Operator</span><span>02:58</span></div>
            <div class="track-row" style="border:none; color:#ff3e3e;"><span>4. Outro (The Rise)</span><span>03:30</span></div>
        </div>

        <a href="https://ditto.fm/decline-ep-smash-rhymes" class="btn">STREAM NOW</a>
    </div>
</div>

<script>
    let reach = 1200;
    setInterval(() => {
        reach += Math.floor(Math.random() * 8) + 1;
        document.getElementById('reach').innerText = reach.toLocaleString();
    }, 3000);
</script>

</body>
</html>
